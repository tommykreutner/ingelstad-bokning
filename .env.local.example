# Supabase - hämta från https://supabase.com/dashboard/project/[ditt-projekt]/settings/api
NEXT_PUBLIC_SUPABASE_URL=https://DITT-PROJEKT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=din-anon-key-här
SUPABASE_SERVICE_ROLE_KEY=din-service-role-key-här

# App URL (ändra när du driftsätter)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# OBS: E-postinställningar (SMTP-server, port, användare, lösenord) 
# konfigureras direkt i admin-panelen under Admin → E-post.
# Inga e-postvariabler behövs här.
